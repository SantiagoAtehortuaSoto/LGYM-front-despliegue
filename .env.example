# Puerto expuesto por Docker Desktop
FRONTEND_PORT=8080

# URL publica del backend accesible desde el navegador.
# No agregues /api aqui salvo que tu backend realmente viva en esa ruta.
# Nunca pongas secretos aqui: este frontend expone solo configuracion publica.
VITE_API_BASE_URL=http://localhost:3000

# Proxy inverso opcional desde nginx para evitar CORS y bloqueos de adblock.
# Ejemplo: https://tu-backend.ngrok-free.dev
API_PROXY_TARGET=

# Opcionales
VITE_API_URL=
VITE_API_URL_OVERRIDE=false
VITE_API_PATH_PREFIX=
VITE_DEV_USE_PROXY=false
VITE_API_PRODUCTOS_URL=
VITE_DIAS_PLAZO_RECLAMO=3
